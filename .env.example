# Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
DATABASE_URL=postgres://upstream:upstream@postgres:5432/upstream_ecom

# Redis
REDIS_URL=redis://redis:6379/0

# Auth (createsuperuser --noinput reads these; no USERNAME needed — custom User uses email)
DJANGO_SUPERUSER_EMAIL=admin@upstream.dev
DJANGO_SUPERUSER_PASSWORD=admin123!

# Stripe (test keys)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Email (console in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# PII Encryption
FIELD_ENCRYPTION_KEY=dev-encryption-key-change-in-production-must-be-32chars!

# PostHog
POSTHOG_API_KEY=phc_placeholder
POSTHOG_HOST=https://app.posthog.com

# Sentry
SENTRY_DSN=

# Frontend (use /api/v1 for Docker—Vite proxies to backend; use http://localhost:8000/api/v1 for separate dev)
VITE_API_BASE_URL=/api/v1
VITE_POSTHOG_KEY=phc_placeholder
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_SENTRY_DSN=
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# CORS (localhost + 127.0.0.1; 5173 = local dev, 5199 = Docker frontend port)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5199,http://127.0.0.1:5173,http://127.0.0.1:5199
